[package]
name = "{{name}}"
version = "0.1.0"
edition = "2024"
rust-version = "1.90"
description = "{{description}}"
authors = ["{{author}}"]
license = "MIT"
repository = "https://github.com/{{owner}}/{{name}}"
homepage = "https://github.com/{{owner}}/{{name}}"
keywords = ["cli"]
categories = ["command-line-utilities"]
readme = "README.md"

[lib]
name = "{{name_snake}}"
path = "src/lib.rs"

[[bin]]
name = "{{name}}"
path = "src/main.rs"

[dependencies]
clap = { version = "4", features = ["derive"] }
clap_complete = "4"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
thiserror = "2"

[dev-dependencies]
jsonschema = { version = "0.46", default-features = false }

[profile.release]
strip = true
lto = true
codegen-units = 1
